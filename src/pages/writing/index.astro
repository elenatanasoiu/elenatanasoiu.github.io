---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import PostCard from "../../components/PostCard.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("creative-writing")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Creative Writing — Elena Tănăsoiu" description="Short fiction and creative writing by Elena Tănăsoiu.">
  <Nav />

  <main class="flex-1 pt-28 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Creative Writing</h1>
      <p class="text-text-secondary mb-12 max-w-lg">
        What happens when a software engineer picks up a pen. Short fiction
        written during creative writing courses at
        <a
          href="https://www.literarykitchen.co.uk"
          target="_blank"
          class="text-teal-400 hover:text-teal-300">Literary Kitchen</a
        >.
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        {
          posts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
              slug={post.id}
              basePath="/writing"
            />
          ))
        }
      </div>
    </div>
  </main>

  <Footer />
</Layout>
