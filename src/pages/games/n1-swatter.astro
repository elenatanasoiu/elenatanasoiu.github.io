---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
---

<Layout ogImage="/images/og-n1-swatter.png" title="" ogImage="/images/og-n1-swatter.png" description="Swat duplicate database queries before they multiply. Miss one and you get N more.">
  <Nav />

  <main class="flex-1 pt-24 pb-8">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-2xl font-bold mb-2">🧹 N+1 Swatter</h1>
      <p class="text-text-muted text-sm mb-4 font-mono">Swat duplicate queries. Miss one and it multiplies.</p>

      <div class="relative inline-block">
        <canvas
          id="game"
          width="700"
          height="500"
          class="rounded-xl border border-surface-600 bg-surface-900 max-w-full"
        ></canvas>

        <div id="start-screen" class="absolute inset-0 flex flex-col items-center justify-center bg-surface-900/85 rounded-xl">
          <p class="text-3xl mb-2">🧹🐈‍⬛</p>
          <p class="text-flame-400 font-mono text-lg mb-2">N+1 Swatter</p>
          <p class="text-text-secondary text-sm mb-4 max-w-xs">Click duplicate queries to swat them.<br/>Miss one and it spawns more. Don't swat unique queries!</p>
          <div class="flex gap-2 mb-4">
            <button data-diff="easy" class="diff-btn bg-teal-500/20 text-teal-400 border border-teal-500/40 px-3 py-1 rounded-lg font-mono text-xs cursor-pointer hover:bg-teal-500/30 transition-colors">Easy</button>
            <button data-diff="normal" class="diff-btn bg-flame-500/20 text-flame-400 border border-flame-500/40 px-3 py-1 rounded-lg font-mono text-xs cursor-pointer hover:bg-flame-500/30 transition-colors ring-2 ring-flame-400">Normal</button>
            <button data-diff="hard" class="diff-btn bg-red-500/20 text-red-400 border border-red-500/40 px-3 py-1 rounded-lg font-mono text-xs cursor-pointer hover:bg-red-500/30 transition-colors">Hard</button>
          </div>
          <button id="start-btn" class="bg-flame-500 hover:bg-flame-600 text-white px-6 py-2 rounded-lg font-mono text-sm cursor-pointer transition-colors">
            Start Game
          </button>
        </div>

        <div id="game-over" class="absolute inset-0 flex flex-col items-center justify-center bg-surface-900/85 rounded-xl hidden">
          <p class="text-flame-400 font-mono text-lg mb-2">CPU Overloaded!</p>
          <p id="final-score" class="text-text-primary font-mono text-2xl mb-1"></p>
          <p id="final-stats" class="text-text-muted text-xs font-mono mb-4"></p>
          <button id="restart-btn" class="bg-flame-500 hover:bg-flame-600 text-white px-6 py-2 rounded-lg font-mono text-sm cursor-pointer transition-colors">
            Play Again
          </button>
        </div>
      </div>

      <div class="flex justify-center gap-8 mt-4 text-sm font-mono">
        <div>
          <span class="text-text-muted">Score: </span>
          <span id="score-display" class="text-flame-400">0</span>
        </div>
        <div>
          <span class="text-text-muted">Wave: </span>
          <span id="wave-display" class="text-teal-400">1</span>
        </div>
        <div>
          <span class="text-text-muted">Best: </span>
          <span id="best-display" class="text-flame-400">0</span>
        </div>
      </div>

      <div class="mt-6">
        <a href="/games" class="text-text-muted hover:text-flame-400 text-sm font-mono">← back to games</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const canvas = document.getElementById("game") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;
  const startScreen = document.getElementById("start-screen")!;
  const gameOverScreen = document.getElementById("game-over")!;
  const startBtn = document.getElementById("start-btn")!;
  const restartBtn = document.getElementById("restart-btn")!;
  const scoreDisplay = document.getElementById("score-display")!;
  const waveDisplay = document.getElementById("wave-display")!;
  const bestDisplay = document.getElementById("best-display")!;

  // Difficulty settings
  type Difficulty = "easy" | "normal" | "hard";
  let selectedDiff: Difficulty = "normal";
  const DIFF_SETTINGS = {
    easy:   { spawnInterval: 130, querySpeed: 260, cpuCreep: 0.01, waveSpeedUp: 5, waveQuerySpeedUp: 8 },
    normal: { spawnInterval: 90,  querySpeed: 180, cpuCreep: 0.02, waveSpeedUp: 8, waveQuerySpeedUp: 12 },
    hard:   { spawnInterval: 55,  querySpeed: 120, cpuCreep: 0.04, waveSpeedUp: 10, waveQuerySpeedUp: 15 },
  };

  document.querySelectorAll(".diff-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      selectedDiff = (btn as HTMLElement).dataset.diff as Difficulty;
      document.querySelectorAll(".diff-btn").forEach(b => b.classList.remove("ring-2", "ring-flame-400", "ring-teal-400", "ring-red-400"));
      const ringColor = selectedDiff === "easy" ? "ring-teal-400" : selectedDiff === "hard" ? "ring-red-400" : "ring-flame-400";
      btn.classList.add("ring-2", ringColor);
    });
  });
  const finalScoreEl = document.getElementById("final-score")!;
  const finalStatsEl = document.getElementById("final-stats")!;

  let best = parseInt(localStorage.getItem("n1-swatter-best") || "0");
  bestDisplay.textContent = best.toString();

  const QUERY_TYPES = [
    { table: "User", action: "Load", unique: false },
    { table: "Repository", action: "Pluck", unique: false },
    { table: "Commit", action: "Find", unique: false },
    { table: "Issue", action: "Load", unique: false },
    { table: "PullRequest", action: "Find", unique: false },
    { table: "Package", action: "Exists?", unique: false },
    { table: "Permission", action: "Check", unique: true },
    { table: "Config", action: "Fetch", unique: true },
    { table: "Session", action: "Validate", unique: true },
  ];

  interface Query {
    x: number; y: number; w: number; h: number;
    table: string; action: string; id: number;
    unique: boolean; timer: number; maxTimer: number;
    spawned: boolean; swatted: boolean; flash: number;
    queryType: number; ms: string;
    isExplain?: boolean;
  }

  interface Burst {
    x: number; y: number; life: number; text: string; color: string;
  }

  const COLS = 4, ROWS = 4;
  const CELL_W = 155, CELL_H = 100;
  const GRID_X = 30, GRID_Y = 55;
  const CELL_PAD = 12;

  let running = false;
  let score = 0, wave = 1, cpu = 0;
  let queries: Query[] = [];
  let bursts: Burst[] = [];
  let totalSwatted = 0, totalMissed = 0, totalFalsePositives = 0;
  let spawnTimer = 0, spawnInterval = 90;
  let activeQueryTypes = 3, querySpeed = 180;
  let frameCount = 0, combo = 0, comboTimer = 0;
  let batchCharges = 0, batchMode = false;

  // EXPLAIN query state
  const EXPLAIN_FIXES = [
    "User.Load called 47 times → add .includes(:user)",
    "Repository.Pluck in a loop → use .where(id: ids)",
    "Commit.Find N+1 → eager load with .preload(:commits)",
    "Issue.Load repeated → batch with .find_each",
    "PullRequest.Find N+1 → use .eager_load(:pulls)",
    "Package.Exists? in loop → use .where(id: ids).exists?",
  ];
  let explainTooltipText = "";
  let explainTooltipTimer = 0;
  const EXPLAIN_TOOLTIP_DURATION = 180; // 3 seconds at 60fps
  let firstExplainSeen = false;
  let goldFlashTimer = 0;

  // Web Audio
  let audioCtx: AudioContext | null = null;
  function getAudio() { if (!audioCtx) audioCtx = new AudioContext(); return audioCtx; }
  function playTone(startFreq: number, endFreq: number, dur: number, type: OscillatorType = "square") {
    const ac = getAudio();
    const osc = ac.createOscillator();
    const gain = ac.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(startFreq, ac.currentTime);
    osc.frequency.linearRampToValueAtTime(endFreq, ac.currentTime + dur);
    gain.gain.setValueAtTime(0.06, ac.currentTime);
    gain.gain.linearRampToValueAtTime(0, ac.currentTime + dur);
    osc.connect(gain).connect(ac.destination);
    osc.start(); osc.stop(ac.currentTime + dur);
  }
  function sndPop() { playTone(600, 600, 0.08); }
  function sndBuzz() { playTone(150, 150, 0.2, "sawtooth"); }
  function sndMultiply() { playTone(400, 200, 0.3); }
  function sndBatch() { playTone(300, 900, 0.3, "sine"); }
  function sndExplain() { playTone(500, 1200, 0.25, "sine"); playTone(800, 1400, 0.15, "sine"); }

  function gridPos(col: number, row: number) {
    return { x: GRID_X + col * (CELL_W + CELL_PAD), y: GRID_Y + row * (CELL_H + CELL_PAD) };
  }

  function findEmptyCell() {
    const occupied = new Set(queries.filter(q => !q.swatted).map(q => `${q.x},${q.y}`));
    const cells: {col: number; row: number}[] = [];
    for (let r = 0; r < ROWS; r++)
      for (let c = 0; c < COLS; c++) {
        const pos = gridPos(c, r);
        if (!occupied.has(`${pos.x},${pos.y}`)) cells.push({col: c, row: r});
      }
    return cells.length ? cells[Math.floor(Math.random() * cells.length)] : null;
  }

  function spawnQuery(forceType?: number, forceDuplicate?: boolean) {
    const cell = findEmptyCell();
    if (!cell) return;
    const pos = gridPos(cell.col, cell.row);
    const available = QUERY_TYPES.slice(0, Math.min(activeQueryTypes + 2, QUERY_TYPES.length));
    const typeIdx = forceType ?? Math.floor(Math.random() * available.length);
    const qt = QUERY_TYPES[typeIdx];
    const isDuplicate = forceDuplicate ?? !qt.unique;

    queries.push({
      x: pos.x, y: pos.y, w: CELL_W, h: CELL_H,
      table: qt.table, action: qt.action,
      id: Math.floor(Math.random() * 999) + 1,
      unique: !isDuplicate, timer: querySpeed, maxTimer: querySpeed,
      spawned: false, swatted: false, flash: 0, queryType: typeIdx,
      ms: (Math.random() * 5 + 0.5).toFixed(1),
    });
  }

  function spawnDuplicates(q: Query, count: number) {
    for (let i = 0; i < count; i++)
      setTimeout(() => { if (running) spawnQuery(q.queryType, true); }, i * 200);
  }

  function spawnExplainQuery() {
    const cell = findEmptyCell();
    if (!cell) return;
    const pos = gridPos(cell.col, cell.row);
    const available = QUERY_TYPES.slice(0, Math.min(activeQueryTypes + 2, QUERY_TYPES.length));
    const typeIdx = Math.floor(Math.random() * available.length);
    const qt = QUERY_TYPES[typeIdx];
    queries.push({
      x: pos.x, y: pos.y, w: CELL_W, h: CELL_H,
      table: qt.table, action: "EXPLAIN",
      id: Math.floor(Math.random() * 999) + 1,
      unique: false, timer: querySpeed * 2.5, maxTimer: querySpeed * 2.5,
      spawned: false, swatted: false, flash: 0, queryType: typeIdx,
      ms: (Math.random() * 5 + 0.5).toFixed(1),
      isExplain: true,
    });
    goldFlashTimer = 6; // ~0.1s gold flash to draw attention
  }

  function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x + r, y);
    c.lineTo(x + w - r, y);
    c.quadraticCurveTo(x + w, y, x + w, y + r);
    c.lineTo(x + w, y + h - r);
    c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    c.lineTo(x + r, y + h);
    c.quadraticCurveTo(x, y + h, x, y + h - r);
    c.lineTo(x, y + r);
    c.quadraticCurveTo(x, y, x + r, y);
    c.closePath();
  }

  function drawQuery(q: Query) {
    if (q.swatted && q.flash <= 0) return;
    const progress = q.timer / q.maxTimer;

    if (q.isExplain) {
      // Animated glow shadow
      const glowPulse = 6 + Math.sin(frameCount * 0.1) * 4;
      ctx.save();
      ctx.shadowColor = "#fbbf24";
      ctx.shadowBlur = glowPulse;

      // Gold pulsing border (3px) — slightly larger card
      const pulse = 0.18 + Math.sin(frameCount * 0.08) * 0.08;
      ctx.fillStyle = `rgba(251, 191, 36, ${pulse})`;
      ctx.strokeStyle = "#fbbf24";
      ctx.lineWidth = 3;
      roundRect(ctx, q.x - 4, q.y - 4, q.w + 8, q.h + 8, 10);
      ctx.fill();
      ctx.stroke();
      ctx.restore();

      // Inner fill — dark gold background
      ctx.fillStyle = "#1f1a08";
      roundRect(ctx, q.x, q.y, q.w, q.h, 8);
      ctx.fill();

      // Timer bar
      ctx.fillStyle = "#24242f";
      ctx.fillRect(q.x + 8, q.y + q.h - 7, q.w - 16, 3);
      ctx.fillStyle = "#fbbf24";
      ctx.fillRect(q.x + 8, q.y + q.h - 7, (q.w - 16) * progress, 3);

      // Big "⚡ EXPLAIN" header
      ctx.fillStyle = "#fbbf24";
      ctx.font = "bold 14px monospace";
      ctx.textAlign = "center";
      ctx.fillText("⚡ EXPLAIN", q.x + q.w / 2, q.y + 20);

      // Table name and details below header
      ctx.fillStyle = "#d4a017";
      ctx.font = "11px monospace";
      ctx.textAlign = "left";
      ctx.fillText(`${q.table}  id: ${q.id}`, q.x + 10, q.y + 40);
      ctx.fillText(`${q.ms}ms`, q.x + 10, q.y + 54);
      ctx.fillStyle = "#fbbf24";
      ctx.font = "bold 10px monospace";
      ctx.textAlign = "right";
      ctx.fillText("+100", q.x + q.w - 10, q.y + 40);

      // "👆 CLICK ME" indicator for the first EXPLAIN card ever
      if (!firstExplainSeen) {
        const bounce = Math.sin(frameCount * 0.12) * 4;
        ctx.fillStyle = "#fbbf24";
        ctx.font = "bold 13px monospace";
        ctx.textAlign = "center";
        ctx.fillText("👆 CLICK ME!", q.x + q.w / 2, q.y - 10 + bounce);
      }
    } else {
      // Background
      ctx.fillStyle = q.unique ? "#0d948820" : progress > 0.5 ? "#1a1a25" : progress > 0.25 ? "#f9731620" : "#ea580c30";
      ctx.strokeStyle = q.unique ? "#14b8a640" : progress > 0.25 ? "#24242f" : "#ea580c60";
      ctx.lineWidth = 1;
      roundRect(ctx, q.x, q.y, q.w, q.h, 8);
      ctx.fill();
      ctx.stroke();

      // Timer bar
      ctx.fillStyle = "#24242f";
      ctx.fillRect(q.x + 8, q.y + q.h - 7, q.w - 16, 3);
      ctx.fillStyle = progress > 0.5 ? "#4ade80" : progress > 0.25 ? "#fb923c" : "#ef4444";
      ctx.fillRect(q.x + 8, q.y + q.h - 7, (q.w - 16) * progress, 3);

      // Text
      ctx.fillStyle = "#a0a0b0";
      ctx.font = "bold 11px monospace";
      ctx.textAlign = "left";
      ctx.fillText(`${q.table} ${q.action}`, q.x + 10, q.y + 22);
      ctx.fillStyle = "#6b6b7b";
      ctx.font = "10px monospace";
      ctx.fillText(`id: ${q.id}`, q.x + 10, q.y + 38);
      ctx.fillText(`${q.ms}ms`, q.x + 10, q.y + 52);

      if (q.unique) {
        ctx.fillStyle = "#14b8a6";
        ctx.font = "9px monospace";
        ctx.textAlign = "right";
        ctx.fillText("unique", q.x + q.w - 10, q.y + 22);
      } else if (progress < 0.3) {
        ctx.fillStyle = "#ef4444";
        ctx.font = "9px monospace";
        ctx.textAlign = "right";
        ctx.fillText("N+1!", q.x + q.w - 10, q.y + 22);
      }
    }

    if (q.flash > 0) {
      ctx.fillStyle = `rgba(239, 68, 68, ${q.flash / 30})`;
      roundRect(ctx, q.x, q.y, q.w, q.h, 8);
      ctx.fill();
    }
  }

  function drawHUD() {
    ctx.fillStyle = "#a0a0b0";
    ctx.font = "11px monospace";
    ctx.textAlign = "left";
    ctx.fillText("CPU:", 15, 25);

    ctx.fillStyle = "#24242f";
    ctx.fillRect(55, 15, 200, 14);
    ctx.fillStyle = cpu > 80 ? "#ef4444" : cpu > 50 ? "#fb923c" : "#4ade80";
    ctx.fillRect(55, 15, cpu * 2, 14);
    ctx.fillStyle = "#f0f0f5";
    ctx.font = "bold 10px monospace";
    ctx.textAlign = "center";
    ctx.fillText(`${Math.round(cpu)}%`, 155, 26);

    ctx.textAlign = "right";
    ctx.fillStyle = "#6b6b7b";
    ctx.font = "11px monospace";
    ctx.fillText(`Wave ${wave}`, canvas.width - 15, 25);

    if (combo > 1 && comboTimer > 0) {
      ctx.fillStyle = "#fbbf24";
      ctx.font = "bold 12px monospace";
      ctx.fillText(`x${combo} combo!`, canvas.width - 15, 42);
    }

    // Batch button
    if (batchCharges > 0) {
      ctx.textAlign = "left";
      if (batchMode) {
        ctx.fillStyle = "#7c3aed";
        roundRect(ctx, 15, 34, 100, 20, 4);
        ctx.fill();
        ctx.fillStyle = "#f0f0f5";
        ctx.font = "bold 10px monospace";
        ctx.fillText("▶ SELECT", 25, 48);
      } else {
        ctx.fillStyle = "#4c1d95";
        roundRect(ctx, 15, 34, 100, 20, 4);
        ctx.fill();
        ctx.strokeStyle = "#7c3aed";
        ctx.lineWidth = 1;
        roundRect(ctx, 15, 34, 100, 20, 4);
        ctx.stroke();
        ctx.fillStyle = "#c084fc";
        ctx.font = "bold 10px monospace";
        ctx.fillText(`BATCH [B] x${batchCharges}`, 22, 48);
      }
    }
  }

  function drawBursts() {
    for (const b of bursts) {
      ctx.globalAlpha = b.life / 40;
      ctx.fillStyle = b.color;
      ctx.font = "bold 13px monospace";
      ctx.textAlign = "center";
      ctx.fillText(b.text, b.x, b.y);
      ctx.globalAlpha = 1;
    }
  }

  function handleClick(mx: number, my: number) {
    if (!running) return;
    if (explainTooltipTimer > 0) return; // Ignore clicks during tooltip

    // Batch button click
    if (batchCharges > 0 && !batchMode && mx >= 15 && mx <= 115 && my >= 34 && my <= 54) {
      batchMode = true;
      return;
    }

    for (let i = queries.length - 1; i >= 0; i--) {
      const q = queries[i];
      if (q.swatted) continue;
      if (mx >= q.x && mx <= q.x + q.w && my >= q.y && my <= q.y + q.h) {
        if (q.isExplain) {
          q.swatted = true;
          score += 100;
          firstExplainSeen = true;
          explainTooltipText = EXPLAIN_FIXES[Math.floor(Math.random() * EXPLAIN_FIXES.length)];
          explainTooltipTimer = EXPLAIN_TOOLTIP_DURATION;
          bursts.push({x: q.x + q.w/2, y: q.y, text: "⚡ +100", color: "#fbbf24", life: 40});
          sndExplain();
        } else if (q.unique) {
          q.flash = 30;
          totalFalsePositives++;
          score = Math.max(0, score - 50);
          cpu = Math.min(100, cpu + 5);
          combo = 0;
          bursts.push({x: q.x + q.w/2, y: q.y, text: "⚠️ Needed!", color: "#ef4444", life: 40});
          sndBuzz();
          if (batchMode) batchMode = false;
        } else if (batchMode) {
          batchMode = false;
          batchCharges--;
          const targets = queries.filter(t => !t.swatted && !t.unique && t.queryType === q.queryType);
          let batchCount = 0;
          for (const t of targets) {
            t.swatted = true;
            batchCount++;
            totalSwatted++;
            score += 20;
            cpu = Math.max(0, cpu - 2);
            bursts.push({x: t.x + t.w/2, y: t.y, text: "+20", color: "#a78bfa", life: 40});
          }
          sndBatch();
          bursts.push({x: canvas.width / 2, y: canvas.height / 2, text: `BATCH x${batchCount}!`, color: "#c084fc", life: 50});
        } else {
          q.swatted = true;
          combo++;
          comboTimer = 90;
          const points = 10 * combo;
          score += points;
          totalSwatted++;
          cpu = Math.max(0, cpu - 2);
          bursts.push({x: q.x + q.w/2, y: q.y, text: `+${points}`, color: "#4ade80", life: 40});
          sndPop();
          if (combo > 0 && combo % 3 === 0) {
            batchCharges++;
            bursts.push({x: q.x + q.w/2, y: q.y - 15, text: "🔋 BATCH!", color: "#c084fc", life: 40});
          }
        }
        scoreDisplay.textContent = score.toString();
        return;
      }
    }
  }

  function update() {
    frameCount++;

    // Tick tooltip timer (always, even when paused)
    if (explainTooltipTimer > 0) {
      explainTooltipTimer--;
      // While tooltip is showing, only animate bursts, skip all game logic
      for (const b of bursts) { b.y -= 0.8; b.life--; }
      bursts = bursts.filter(b => b.life > 0);
      return;
    }

    spawnTimer++;
    if (spawnTimer >= spawnInterval) { spawnTimer = 0; spawnQuery(); }

    for (const q of queries) {
      if (q.swatted) continue;
      q.timer--;
      if (q.flash > 0) q.flash--;
      if (q.timer <= 0 && !q.spawned) {
        q.spawned = true;
        if (!q.unique && !q.isExplain) {
          totalMissed++;
          cpu = Math.min(100, cpu + 8);
          combo = 0;
          const dupes = Math.min(2 + Math.floor(wave / 3), 4);
          spawnDuplicates(q, dupes);
          bursts.push({x: q.x + q.w/2, y: q.y, text: `x${dupes} N+1!`, color: "#ef4444", life: 40});
          sndMultiply();
        }
        q.swatted = true;
      }
    }

    queries = queries.filter(q => !q.swatted || q.flash > 0);
    for (const b of bursts) { b.y -= 0.8; b.life--; }
    bursts = bursts.filter(b => b.life > 0);
    if (comboTimer > 0) comboTimer--;
    if (comboTimer === 0) combo = 0;
    if (goldFlashTimer > 0) goldFlashTimer--;
    cpu = Math.min(100, cpu + DIFF_SETTINGS[selectedDiff].cpuCreep);

    if (frameCount % 600 === 0) {
      wave++;
      waveDisplay.textContent = wave.toString();
      const ds = DIFF_SETTINGS[selectedDiff];
      spawnInterval = Math.max(30, ds.spawnInterval - wave * ds.waveSpeedUp);
      querySpeed = Math.max(80, ds.querySpeed - wave * ds.waveQuerySpeedUp);
      if (wave % 2 === 0 && activeQueryTypes < QUERY_TYPES.length) activeQueryTypes++;
      if (wave % 3 === 0) spawnExplainQuery();
    }

    if (cpu >= 100) gameOver();
  }

  function draw() {
    ctx.fillStyle = "#050508";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Gold flash when EXPLAIN card spawns
    if (goldFlashTimer > 0) {
      ctx.fillStyle = `rgba(251, 191, 36, ${0.12 * (goldFlashTimer / 6)})`;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
    ctx.strokeStyle = "#13131f";
    ctx.lineWidth = 1;
    for (let r = 0; r < ROWS; r++)
      for (let c = 0; c < COLS; c++) {
        const pos = gridPos(c, r);
        roundRect(ctx, pos.x, pos.y, CELL_W, CELL_H, 8);
        ctx.stroke();
      }
    for (const q of queries) drawQuery(q);
    drawBursts();
    drawHUD();

    // EXPLAIN tooltip overlay
    if (explainTooltipTimer > 0) {
      const alpha = Math.min(1, explainTooltipTimer / 20, (EXPLAIN_TOOLTIP_DURATION - explainTooltipTimer + 1) / 20);
      ctx.fillStyle = `rgba(5, 5, 8, ${0.7 * alpha})`;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      const boxW = 500, boxH = 70;
      const boxX = (canvas.width - boxW) / 2, boxY = (canvas.height - boxH) / 2;

      ctx.fillStyle = `rgba(26, 22, 8, ${0.95 * alpha})`;
      ctx.strokeStyle = `rgba(251, 191, 36, ${alpha})`;
      ctx.lineWidth = 2;
      roundRect(ctx, boxX, boxY, boxW, boxH, 12);
      ctx.fill();
      ctx.stroke();

      ctx.globalAlpha = alpha;
      ctx.fillStyle = "#fbbf24";
      ctx.font = "bold 13px monospace";
      ctx.textAlign = "center";
      ctx.fillText("⚡ EXPLAIN", canvas.width / 2, boxY + 24);
      ctx.fillStyle = "#e0d0a0";
      ctx.font = "12px monospace";
      ctx.fillText(explainTooltipText, canvas.width / 2, boxY + 48);
      ctx.globalAlpha = 1;
    }
  }

  function gameLoop() {
    if (!running) return;
    update(); draw();
    requestAnimationFrame(gameLoop);
  }

  function gameOver() {
    running = false;
    if (score > best) {
      best = score;
      localStorage.setItem("n1-swatter-best", best.toString());
      bestDisplay.textContent = best.toString();
    }
    finalScoreEl.textContent = `Score: ${score}`;
    finalStatsEl.textContent = `Swatted: ${totalSwatted} | Missed: ${totalMissed} | False positives: ${totalFalsePositives} | Wave: ${wave}`;
    gameOverScreen.classList.remove("hidden");
  }

  function startGame() {
    const ds = DIFF_SETTINGS[selectedDiff];
    score = 0; wave = 1; cpu = 0; frameCount = 0;
    spawnTimer = 0; spawnInterval = ds.spawnInterval; querySpeed = ds.querySpeed;
    activeQueryTypes = 3; combo = 0; comboTimer = 0;
    batchCharges = 0; batchMode = false;
    explainTooltipText = ""; explainTooltipTimer = 0;
    firstExplainSeen = false; goldFlashTimer = 0;
    totalSwatted = 0; totalMissed = 0; totalFalsePositives = 0;
    queries = []; bursts = [];
    scoreDisplay.textContent = "0";
    waveDisplay.textContent = "1";
    startScreen.classList.add("hidden");
    gameOverScreen.classList.add("hidden");
    running = true;
    gameLoop();
  }

  function getCanvasCoords(e: MouseEvent | Touch) {
    const rect = canvas.getBoundingClientRect();
    return {
      x: (e.clientX - rect.left) * (canvas.width / rect.width),
      y: (e.clientY - rect.top) * (canvas.height / rect.height),
    };
  }

  canvas.addEventListener("click", e => {
    if (!running) return;
    const {x, y} = getCanvasCoords(e);
    handleClick(x, y);
  });
  canvas.addEventListener("touchstart", e => {
    e.preventDefault();
    if (!running) { startGame(); return; }
    const {x, y} = getCanvasCoords(e.touches[0]);
    handleClick(x, y);
  });
  startBtn.addEventListener("click", e => { e.stopPropagation(); startGame(); });
  restartBtn.addEventListener("click", e => { e.stopPropagation(); startGame(); });
  document.addEventListener("keydown", e => {
    if (!running) return;
    if (e.key === "b" || e.key === "B") {
      if (batchCharges > 0 && !batchMode) batchMode = true;
      else if (batchMode) batchMode = false;
    }
  });

  draw();
</script>
