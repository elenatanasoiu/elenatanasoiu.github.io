---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
---

<Layout ogImage="/images/og-cache-cat.png" title="" ogImage="/images/og-cache-cat.png" description="A caching plate-spinner where you're a cat managing a cache layer">
  <Nav />
  <main class="flex-1 pt-24 pb-8">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-2xl font-bold text-text-primary mb-4 font-mono">🐈‍⬛ Cache Cat</h1>
      <div class="relative inline-block">
        <canvas id="game" width="700" height="500" class="rounded-xl border border-surface-600 bg-[#050508] max-w-full cursor-pointer"></canvas>
        <div id="start-screen" class="absolute inset-0 flex flex-col items-center justify-center bg-surface-900/90 rounded-xl z-10">
          <div class="text-5xl mb-3">🐈‍⬛</div>
          <h2 class="text-xl font-bold text-text-primary mb-3 font-mono">Cache Cat</h2>
          <p class="text-text-secondary text-sm max-w-sm mb-3 font-mono leading-relaxed text-left px-4">
            Requests stream in — serve them fast!
          </p>
          <div class="text-sm max-w-sm mb-3 font-mono leading-relaxed text-left px-4">
            <p class="text-flame-400 font-bold text-xs mb-2 uppercase tracking-wider">How to Play</p>
            <p class="text-text-secondary mb-1"><span class="text-teal-400">1.</span> Requests arrive from the right →</p>
            <p class="text-text-secondary mb-1"><span class="text-teal-400">2.</span> Click a <span class="text-teal-400">CACHE SLOT</span> to serve a matching request instantly</p>
            <p class="text-text-secondary mb-3"><span class="text-teal-400">3.</span> Click a <span class="text-flame-400">REQUEST</span> to fetch it (slower), then click a slot to cache it</p>
          </div>
          <p class="text-text-secondary text-xs max-w-sm mb-5 font-mono leading-relaxed text-left px-4">
            ⚠️ Entries go stale: <span class="text-green-400">■</span> → <span class="text-yellow-400">■</span> → <span class="text-red-400">■</span> — serving stale data loses a life!
          </p>
          <button id="start-btn" class="bg-flame-500 hover:bg-flame-600 text-white px-6 py-2 rounded-lg font-mono text-sm transition-colors">Start Caching</button>
        </div>
        <div id="game-over" class="absolute inset-0 flex flex-col items-center justify-center bg-surface-900/90 rounded-xl z-10 hidden">
          <div class="text-4xl mb-2">😿</div>
          <h2 class="text-xl font-bold text-text-primary mb-2 font-mono">Cache Invalidated!</h2>
          <p id="final-score" class="text-flame-400 text-lg font-mono mb-1"></p>
          <p id="final-stats" class="text-text-secondary text-xs font-mono mb-4 max-w-xs leading-relaxed"></p>
          <button id="restart-btn" class="bg-flame-500 hover:bg-flame-600 text-white px-6 py-2 rounded-lg font-mono text-sm transition-colors">Retry</button>
        </div>
      </div>
      <div class="flex justify-center gap-6 mt-4 text-sm font-mono flex-wrap">
        <div><span class="text-text-muted">Score </span><span id="hud-score" class="text-flame-400">0</span></div>
        <div><span class="text-text-muted">Hits </span><span id="hud-hits" class="text-teal-400">0%</span></div>
        <div><span class="text-text-muted">Budget </span><span id="hud-budget" class="text-green-400">1000ms</span></div>
        <div><span class="text-text-muted">Best </span><span id="hud-best" class="text-flame-400">0</span></div>
      </div>
      <a href="/games" class="inline-block mt-6 text-text-secondary hover:text-flame-400 text-sm font-mono transition-colors">← back to games</a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
const canvas = document.getElementById("game") as HTMLCanvasElement;
const ctx = canvas.getContext("2d")!;
const W = 700, H = 500;
const el = (id: string) => document.getElementById(id)!;
const startScr = el("start-screen"), overScr = el("game-over");
const hudScore = el("hud-score"), hudHits = el("hud-hits");
const hudBudget = el("hud-budget"), hudBest = el("hud-best");
const finalScoreEl = el("final-score"), finalStatsEl = el("final-stats");

const RES = [
  { key: "users:42",  col: "#60a5fa", w: 5 },
  { key: "repo:cfg",  col: "#a78bfa", w: 4 },
  { key: "org:perms", col: "#f472b6", w: 3 },
  { key: "img:ava",   col: "#34d399", w: 3 },
  { key: "api:tok",   col: "#fbbf24", w: 2 },
  { key: "sess:auth", col: "#fb923c", w: 2 },
  { key: "cfg:flags", col: "#14b8a6", w: 1 },
  { key: "db:pool",   col: "#ef4444", w: 1 },
];
const TOT_W = RES.reduce((s, r) => s + r.w, 0);

const SLOTS = 6, SL_W = 130, SL_H = 52, SL_G = 7, SL_X = 14, SL_Y0 = 68;
const RR = 24, DEAD_X = 168;

interface Entry { key: string; col: string; at: number }
interface Req { key: string; col: string; x: number; y: number; spd: number; st: "move"|"fetch"|"done"; fp: number; fd: number }
interface Pt { x: number; y: number; vx: number; vy: number; l: number; ml: number; col: string; t?: string }

let run = false, score = 0, lives = 3, budget = 1000, timer = 90;
let hits = 0, fetches = 0, stales = 0, timeouts = 0, served = 0;
let gt = 0, spT = 0, lastT = 0, blinkT = 4;
let cache: (Entry | null)[] = [], reqs: Req[] = [], pts: Pt[] = [];
let pend: { key: string; col: string; t: number } | null = null;
let evictFlash: number[] = Array(SLOTS).fill(0);
let tutorialServed = 0, tutorialSpawned = 0, totalSpawned = 0;
let tutorialKeys: { key: string; col: string }[] = [];
let audioCtx: AudioContext | null = null;
function initAudio() { if (!audioCtx) audioCtx = new AudioContext(); }
function sndTone(freq: number, dur: number, type: OscillatorType = "sine") {
  if (!audioCtx) return;
  const o = audioCtx.createOscillator(), g = audioCtx.createGain();
  o.type = type; o.frequency.setValueAtTime(freq, audioCtx.currentTime);
  g.gain.setValueAtTime(0.06, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
  o.connect(g); g.connect(audioCtx.destination);
  o.start(); o.stop(audioCtx.currentTime + dur);
}
function sndHit() { sndTone(800, 0.1); }
function sndStale() { sndTone(200, 0.15, "square"); }
function sndFetch() {
  if (!audioCtx) return;
  const g = audioCtx.createGain(); g.gain.setValueAtTime(0.06, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.2);
  g.connect(audioCtx.destination);
  for (let i = 0; i < 4; i++) {
    const o = audioCtx.createOscillator();
    o.type = "square"; o.frequency.value = i % 2 === 0 ? 300 : 350;
    o.connect(g); o.start(audioCtx.currentTime + i * 0.05);
    o.stop(audioCtx.currentTime + (i + 1) * 0.05);
  }
}
function sndCache() {
  if (!audioCtx) return;
  const o = audioCtx.createOscillator(), g = audioCtx.createGain();
  o.frequency.setValueAtTime(500, audioCtx.currentTime);
  o.frequency.linearRampToValueAtTime(600, audioCtx.currentTime + 0.12);
  g.gain.setValueAtTime(0.06, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.12);
  o.connect(g); g.connect(audioCtx.destination);
  o.start(); o.stop(audioCtx.currentTime + 0.12);
}
let best = parseInt(localStorage.getItem("cache-cat-best") || "0");
hudBest.textContent = best.toString();

const lerp = (a: number, b: number, t: number) => a + (b - a) * Math.max(0, Math.min(1, t));
const rr = (x: number, y: number, w: number, h: number, r: number) => { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); };

function fCol(f: number): string {
  if (f > .66) { const t = (f-.66)/.34; return `rgb(${lerp(251,74,t)},${lerp(191,222,t)},${lerp(36,128,t)})`; }
  if (f > .33) { const t = (f-.33)/.33; return `rgb(251,${lerp(146,191,t)},${lerp(60,36,t)})`; }
  return `rgb(239,${lerp(68,146,f/.33)},68)`;
}

function diff() {
  const t = Math.min(1, (90 - timer) / 90);
  return { int: lerp(2.6, .85, t), spd: lerp(35, 72, t), ttl: lerp(14, 5.5, t), ft: lerp(2.2, 1.0, t) };
}

function randRes() {
  let r = Math.random() * TOT_W;
  for (const x of RES) { r -= x.w; if (r <= 0) return x; }
  return RES[0];
}

function fresh(e: Entry) { return Math.max(0, 1 - (gt - e.at) / diff().ttl); }

function coords(e: MouseEvent | Touch) {
  const r = canvas.getBoundingClientRect();
  return { x: (e.clientX - r.left) * W / r.width, y: (e.clientY - r.top) * H / r.height };
}

function emit(x: number, y: number, txt: string, col: string, n = 5) {
  pts.push({ x, y, vx: 0, vy: -28, l: 1.3, ml: 1.3, col, t: txt });
  for (let i = 0; i < n; i++) {
    const a = Math.random() * Math.PI * 2;
    pts.push({ x, y, vx: Math.cos(a)*55, vy: Math.sin(a)*55, l: .5, ml: .5, col });
  }
}

function spawn() {
  const r = tutorialSpawned < 2 && tutorialSpawned < tutorialKeys.length ? tutorialKeys[tutorialSpawned++] : randRes();
  let y = 85 + Math.random() * (H - 150);
  for (const q of reqs) { if (Math.abs(q.y - y) < RR * 2.2 && q.x > 480) y = 85 + Math.random() * (H - 150); }
  const spd = totalSpawned < 3 ? diff().spd * 0.5 : diff().spd;
  reqs.push({ key: r.key, col: r.col, x: W + RR, y, spd, st: "move", fp: 0, fd: diff().ft });
  totalSpawned++;
}

function handleClick(mx: number, my: number) {
  for (let i = 0; i < SLOTS; i++) {
    const sy = SL_Y0 + i * (SL_H + SL_G);
    if (mx >= SL_X && mx <= SL_X + SL_W && my >= sy && my <= sy + SL_H) {
      const ec = cache[i];
      if (ec && fresh(ec) < 0.5) {
        const bx = SL_X + SL_W - 14, by = sy + 2;
        if (mx >= bx && mx <= bx + 12 && my >= by && my <= by + 12) {
          cache[i] = null; evictFlash[i] = 0.35;
          sndTone(400, 0.08, "triangle"); return;
        }
      }
      if (pend) {
        cache[i] = { key: pend.key, col: pend.col, at: gt };
        emit(SL_X + SL_W / 2, sy + SL_H / 2, "CACHED!", "#14b8a6", 3);
        score += 10; pend = null; sndCache(); return;
      }
      const e = cache[i]; if (!e) return;
      let req: Req | undefined;
      for (const r of reqs) if (r.st === "move" && r.key === e.key && (!req || r.x < req.x)) req = r;
      if (!req) { emit(SL_X + SL_W / 2, sy + SL_H / 2, "NO MATCH", "#555", 0); return; }
      const f = fresh(e);
      if (f > .2) {
        const p = Math.floor(120 * f);
        score += p; hits++; served++; req.st = "done";
        emit(req.x, req.y, `HIT! +${p}`, "#14b8a6", 8);
        sndHit(); if (tutorialServed < 2) tutorialServed++;
      } else {
        score -= 200; lives--; stales++; served++; req.st = "done"; cache[i] = null;
        emit(req.x, req.y, "STALE! -200", "#ef4444", 12); sndStale();
      }
      return;
    }
  }
  for (const r of reqs) {
    if (r.st !== "move") continue;
    if ((mx - r.x) ** 2 + (my - r.y) ** 2 <= (RR * 1.3) ** 2) {
      r.st = "fetch"; r.fp = 0; sndFetch(); return;
    }
  }
}

function update(dt: number) {
  gt += dt; timer -= dt; spT -= dt;
  blinkT -= dt; if (blinkT <= 0) blinkT = 2.5 + Math.random() * 4;
  if (spT <= 0) { spawn(); spT = diff().int; }

  for (const r of reqs) {
    if (r.st === "move") {
      r.x -= r.spd * dt;
      if (r.x < DEAD_X) {
        r.st = "done"; budget -= 100; timeouts++; served++; score -= 50;
        emit(r.x, r.y, "TIMEOUT!", "#fb923c", 4);
      }
    } else if (r.st === "fetch") {
      r.fp += dt / r.fd;
      if (r.fp >= 1) {
        r.st = "done"; score += 20; fetches++; served++; budget -= 30;
        pend = { key: r.key, col: r.col, t: 5 };
        emit(r.x, r.y, "FETCHED +20", "#a78bfa", 3);
      }
    }
  }
  reqs = reqs.filter(r => r.st !== "done");
  if (pend) { pend.t -= dt; if (pend.t <= 0) pend = null; }
  for (const p of pts) { p.x += p.vx * dt; p.y += p.vy * dt; p.l -= dt; }
  pts = pts.filter(p => p.l > 0);
  for (let i = 0; i < SLOTS; i++) if (evictFlash[i] > 0) evictFlash[i] = Math.max(0, evictFlash[i] - dt);

  hudScore.textContent = score.toString();
  const r = served > 0 ? Math.round(hits / served * 100) : 0;
  hudHits.textContent = `${r}%`;
  hudBudget.textContent = `${Math.max(0, budget)}ms`;
  hudBudget.style.color = budget > 500 ? "#4ade80" : budget > 200 ? "#fbbf24" : "#ef4444";
  if (timer <= 0 || lives <= 0 || budget <= 0) endGame();
}

function drawCat(cx: number, cy: number) {
  ctx.fillStyle = "#1a1a2e";
  ctx.beginPath(); ctx.ellipse(cx, cy + 8, 18, 24, 0, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(cx, cy - 18, 14, 0, Math.PI * 2); ctx.fill();
  for (const s of [-1, 1]) {
    ctx.beginPath(); ctx.moveTo(cx+s*11,cy-29); ctx.lineTo(cx+s*6,cy-44); ctx.lineTo(cx+s*1,cy-29); ctx.fill();
  }
  ctx.fillStyle = "#fbbf24";
  const bk = blinkT < .15;
  for (const s of [-1, 1]) { ctx.beginPath(); ctx.ellipse(cx+s*5,cy-20,2.5,bk?.5:3.5,0,0,Math.PI*2); ctx.fill(); }
  if (!bk) { ctx.fillStyle = "#050508"; for (const s of [-1,1]) { ctx.beginPath(); ctx.ellipse(cx+s*5,cy-20,1,2.5,0,0,Math.PI*2); ctx.fill(); } }
  ctx.strokeStyle = "#1a1a2e"; ctx.lineWidth = 3.5; ctx.lineCap = "round";
  ctx.beginPath(); ctx.moveTo(cx+14, cy+24);
  const tw = Math.sin(gt * 2.5) * 14;
  ctx.quadraticCurveTo(cx+30+tw, cy+6, cx+26+tw, cy-8); ctx.stroke();
  ctx.lineCap = "butt";
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = "#050508"; ctx.fillRect(0, 0, W, H);

  // Subtle grid
  ctx.strokeStyle = "#0a0a13"; ctx.lineWidth = .5;
  for (let x = 0; x < W; x += 28) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
  for (let y = 0; y < H; y += 28) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }

  // HUD bar
  ctx.fillStyle = "#0a0a14"; ctx.fillRect(0, 0, W, 48);
  ctx.strokeStyle = "#1a1a28"; ctx.lineWidth = .5;
  ctx.beginPath(); ctx.moveTo(0,48); ctx.lineTo(W,48); ctx.stroke();
  ctx.font = "bold 13px monospace"; ctx.textAlign = "left";
  ctx.fillStyle = timer < 15 ? "#ef4444" : "#e2e8f0";
  ctx.fillText(`⏱ ${Math.max(0,Math.ceil(timer))}s`, 14, 22);
  ctx.fillStyle = "#e2e8f0"; ctx.textAlign = "center";
  const phase = (90 - timer) < 20 ? "WARM-UP" : (90 - timer) < 55 ? "STEADY" : "CRUNCH";
  ctx.fillStyle = phase === "CRUNCH" ? "#ef4444" : "#666"; ctx.font = "bold 10px monospace";
  ctx.fillText(phase, W / 2, 22);
  ctx.textAlign = "right"; ctx.font = "16px monospace"; ctx.fillStyle = "#ef4444";
  ctx.fillText("♥".repeat(Math.max(0, lives)), W - 14, 24);
  // Budget bar
  ctx.fillStyle = "#222"; rr(14, 32, 200, 8, 4); ctx.fill();
  const bc = budget > 500 ? "#4ade80" : budget > 200 ? "#fbbf24" : "#ef4444";
  ctx.fillStyle = bc; rr(14, 32, 200 * Math.max(0, budget) / 1000, 8, 4); ctx.fill();
  ctx.fillStyle = "#888"; ctx.font = "8px monospace"; ctx.textAlign = "left";
  ctx.fillText(`BUDGET ${Math.max(0, budget)}ms`, 220, 40);

  // Tutorial help text (first 10 seconds)
  if (gt > 0 && gt < 10) {
    let helpText = "";
    let helpCol = "#14b8a6";
    if (pend) {
      helpText = "\u2B07 Now click an empty slot to cache it!";
      helpCol = "#a78bfa";
    } else {
      let hasMatch = false;
      for (const r of reqs) {
        if (r.st !== "move") continue;
        for (let i = 0; i < SLOTS; i++) {
          const e = cache[i];
          if (e && e.key === r.key) { hasMatch = true; break; }
        }
        if (hasMatch) break;
      }
      if (hasMatch) {
        helpText = "\u2190 Click the matching slot to serve!";
        helpCol = "#14b8a6";
      } else if (reqs.some(r => r.st === "move")) {
        helpText = "Click the bubble to fetch it \u2192";
        helpCol = "#fb923c";
      }
    }
    if (helpText) {
      ctx.save();
      ctx.fillStyle = helpCol;
      ctx.globalAlpha = 0.7 + Math.sin(gt * 4) * 0.3;
      ctx.font = "bold 12px monospace";
      ctx.textAlign = "center";
      ctx.fillText(helpText, W / 2, 62);
      ctx.globalAlpha = 1;
      ctx.restore();
    }
  }

  // Cache panel
  ctx.fillStyle = "#08080f"; rr(6, 54, SL_W + 20, SLOTS * (SL_H + SL_G) + 20, 10); ctx.fill();
  ctx.fillStyle = "#14b8a6"; ctx.font = "bold 9px monospace"; ctx.textAlign = "center";
  ctx.fillText("▸ CACHE", SL_X + SL_W / 2, SL_Y0 - 5);

  for (let i = 0; i < SLOTS; i++) {
    const sy = SL_Y0 + i * (SL_H + SL_G), e = cache[i];
    ctx.fillStyle = e ? "#0f0f1e" : "#0a0a14"; rr(SL_X, sy, SL_W, SL_H, 6); ctx.fill();
    if (e) {
      const f = fresh(e), fc = fCol(f);
      ctx.strokeStyle = fc; ctx.lineWidth = f <= .25 ? 2.5 : 1.5; rr(SL_X,sy,SL_W,SL_H,6); ctx.stroke();
      if (f <= .25) { ctx.fillStyle = `rgba(239,68,68,${.08+Math.sin(gt*8)*.04})`; rr(SL_X,sy,SL_W,SL_H,6); ctx.fill(); }
      ctx.fillStyle = "#e2e8f0"; ctx.font = "bold 10px monospace"; ctx.textAlign = "left";
      ctx.fillText(e.key, SL_X+8, sy+17);
      ctx.fillStyle = "#222"; rr(SL_X+8,sy+24,SL_W-16,5,2); ctx.fill();
      ctx.fillStyle = fc; rr(SL_X+8,sy+24,(SL_W-16)*f,5,2); ctx.fill();
      ctx.fillStyle = fc; ctx.font = "8px monospace";
      ctx.fillText(`${(gt-e.at).toFixed(1)}s`, SL_X+8, sy+42);
      if (f <= .25) { ctx.fillStyle = "#ef4444"; ctx.font = "bold 8px monospace"; ctx.textAlign = "right"; ctx.fillText("STALE!", SL_X+SL_W-8, sy+42); }
      if (f < 0.5) {
        const bx = SL_X + SL_W - 14, by2 = sy + 2;
        ctx.fillStyle = "rgba(239,68,68,0.7)"; rr(bx, by2, 12, 12, 3); ctx.fill();
        ctx.strokeStyle = "#fff"; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.moveTo(bx+3, by2+3); ctx.lineTo(bx+9, by2+9); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(bx+9, by2+3); ctx.lineTo(bx+3, by2+9); ctx.stroke();
      }
    } else {
      if (pend) {
        ctx.save();
        ctx.strokeStyle = `rgba(167,139,250,${0.4 + Math.sin(gt * 5) * 0.2})`;
        ctx.lineWidth = 2; ctx.setLineDash([6, 4]); ctx.lineDashOffset = -gt * 30;
        rr(SL_X, sy, SL_W, SL_H, 6); ctx.stroke();
        ctx.setLineDash([]); ctx.restore();
        ctx.fillStyle = `rgba(167,139,250,${0.04 + Math.sin(gt * 5) * 0.02})`;
        rr(SL_X, sy, SL_W, SL_H, 6); ctx.fill();
      } else {
        ctx.strokeStyle = "#161625"; ctx.lineWidth = 1; rr(SL_X,sy,SL_W,SL_H,6); ctx.stroke();
      }
      ctx.fillStyle = pend ? "#a78bfa" : "#2a2a3e"; ctx.font = "9px monospace"; ctx.textAlign = "center";
      ctx.fillText(pend ? "\u25B8 tap to cache" : "[empty]", SL_X+SL_W/2, sy+SL_H/2+3);
    }
    if (evictFlash[i] > 0) {
      ctx.fillStyle = "rgba(239,68,68," + (evictFlash[i] / 0.35 * 0.4) + ")";
      rr(SL_X, sy, SL_W, SL_H, 6); ctx.fill();
    }
  }

  // Deadline line
  ctx.strokeStyle = "#161625"; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.moveTo(DEAD_X, 55); ctx.lineTo(DEAD_X, H - 5); ctx.stroke();
  ctx.setLineDash([]);

  // "REQUESTS" label
  ctx.fillStyle = "#fb923c"; ctx.font = "bold 9px monospace"; ctx.textAlign = "right";
  ctx.fillText("REQUESTS \u2192", W - 10, 62);

  drawCat(210, 290);

  // Requests
  for (const r of reqs) {
    if (r.st === "done") continue;
    ctx.fillStyle = r.col + "15"; ctx.beginPath(); ctx.arc(r.x,r.y,RR+5,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = r.col + "25"; ctx.beginPath(); ctx.arc(r.x,r.y,RR,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle = r.col; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(r.x,r.y,RR,0,Math.PI*2); ctx.stroke();
    ctx.fillStyle = "#fff"; ctx.font = "bold 9px monospace"; ctx.textAlign = "center";
    ctx.fillText(r.key, r.x, r.y + 3);
    if (r.st === "fetch") {
      const bw = RR * 2;
      ctx.fillStyle = "#222"; rr(r.x-RR, r.y+RR+4, bw, 4, 2); ctx.fill();
      ctx.fillStyle = "#a78bfa"; rr(r.x-RR, r.y+RR+4, bw*r.fp, 4, 2); ctx.fill();
      ctx.fillStyle = "#a78bfa80"; ctx.font = "7px monospace"; ctx.fillText("fetching…", r.x, r.y+RR+16);
    }
  }

  // Tutorial highlights
  if (tutorialServed < 2) {
    ctx.save();
    for (const r of reqs) {
      if (r.st !== "move") continue;
      for (let i = 0; i < SLOTS; i++) {
        const e = cache[i]; if (!e || e.key !== r.key) continue;
        const sy = SL_Y0 + i * (SL_H + SL_G);
        const sx = SL_X + SL_W, sy2 = sy + SL_H / 2;
        ctx.strokeStyle = "#14b8a6"; ctx.lineWidth = 2;
        ctx.setLineDash([6, 4]); ctx.lineDashOffset = -gt * 40;
        ctx.shadowColor = "#14b8a6"; ctx.shadowBlur = 8;
        ctx.beginPath(); ctx.moveTo(sx, sy2);
        ctx.quadraticCurveTo((sx + r.x) / 2, (sy2 + r.y) / 2 - 20, r.x - RR, r.y);
        ctx.stroke();
        ctx.setLineDash([]); ctx.shadowBlur = 0;
        ctx.strokeStyle = `rgba(20,184,166,${0.4 + Math.sin(gt * 5) * 0.2})`;
        ctx.lineWidth = 2.5; rr(SL_X, sy, SL_W, SL_H, 6); ctx.stroke();
        break;
      }
    }
    ctx.restore();
    ctx.fillStyle = `rgba(20,184,166,${0.6 + Math.sin(gt * 3) * 0.2})`;
    ctx.font = "bold 11px monospace"; ctx.textAlign = "center";
    ctx.fillText("Click the matching cache slot!", W / 2, H - 46);
  }

  // Pending bar
  if (pend) {
    const by = H - 36;
    ctx.fillStyle = "#0f0f1e"; rr(8,by,W-16,30,8); ctx.fill();
    ctx.strokeStyle = pend.col; ctx.lineWidth = 1.5; rr(8,by,W-16,30,8); ctx.stroke();
    ctx.fillStyle = pend.col + "30"; rr(10,by+2,(W-20)*(pend.t/5),26,7); ctx.fill();
    ctx.fillStyle = "#e2e8f0"; ctx.font = "bold 10px monospace"; ctx.textAlign = "center";
    ctx.fillText(`📦 Cache "${pend.key}"? Click a slot!`, W/2, by+19);
  }

  // Particles
  for (const p of pts) {
    ctx.globalAlpha = p.l / p.ml;
    if (p.t) { ctx.fillStyle = p.col; ctx.font = "bold 13px monospace"; ctx.textAlign = "center"; ctx.fillText(p.t, p.x, p.y); }
    else { ctx.fillStyle = p.col; ctx.beginPath(); ctx.arc(p.x,p.y,2*(p.l/p.ml),0,Math.PI*2); ctx.fill(); }
    ctx.globalAlpha = 1;
  }
}

function startGame() {
  startScr.classList.add("hidden"); overScr.classList.add("hidden");
  score=0; lives=3; budget=1000; timer=90; gt=0; spT=.8; blinkT=3;
  hits=0; fetches=0; stales=0; timeouts=0; served=0; totalSpawned=0;
  cache = Array(SLOTS).fill(null); reqs=[]; pts=[]; pend=null; evictFlash = Array(SLOTS).fill(0);
  tutorialServed = 0; tutorialSpawned = 0;
  const t0 = RES[0], t1 = RES[1];
  tutorialKeys = [{ key: t0.key, col: t0.col }, { key: t1.key, col: t1.col }];
  cache[0] = { key: t0.key, col: t0.col, at: 0 };
  cache[1] = { key: t1.key, col: t1.col, at: 0 };
  initAudio();
  run = true; lastT = performance.now();
  requestAnimationFrame(loop);
}

function endGame() {
  run = false;
  if (score > best) { best = score; localStorage.setItem("cache-cat-best", best.toString()); }
  hudBest.textContent = best.toString();
  finalScoreEl.textContent = `Score: ${score}`;
  const r = served > 0 ? Math.round(hits / served * 100) : 0;
  finalStatsEl.innerHTML = `Hit rate: ${r}% · Requests served: ${served}<br>Cache hits: ${hits} · Source fetches: ${fetches}<br>Stale serves: ${stales} · Timeouts: ${timeouts}<br>Remaining budget: ${Math.max(0,budget)}ms`;
  overScr.classList.remove("hidden");
}

function loop(t: number) {
  if (!run) return;
  const dt = Math.min(.1, (t - lastT) / 1000); lastT = t;
  update(dt); draw();
  requestAnimationFrame(loop);
}

canvas.addEventListener("click", e => { if (run) handleClick(coords(e).x, coords(e).y); });
canvas.addEventListener("touchstart", e => { e.preventDefault(); if (run) { const c = coords(e.touches[0]); handleClick(c.x, c.y); } }, { passive: false });
el("start-btn").addEventListener("click", e => { e.stopPropagation(); startGame(); });
el("restart-btn").addEventListener("click", e => { e.stopPropagation(); startGame(); });

// Keyboard: 1-6 for cache slots
document.addEventListener("keydown", e => {
  if (!run) return;
  const n = parseInt(e.key);
  if (n >= 1 && n <= SLOTS) {
    const sy = SL_Y0 + (n-1) * (SL_H + SL_G);
    handleClick(SL_X + SL_W/2, sy + SL_H/2);
  }
});
</script>
