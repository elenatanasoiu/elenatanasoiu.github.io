<!-- Floating ember particles rising from the bottom -->
<canvas id="embers" class="fixed inset-0 pointer-events-none z-0"></canvas>

<script>
  const canvas = document.getElementById("embers") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  interface Ember {
    x: number;
    y: number;
    size: number;
    speed: number;
    opacity: number;
    drift: number;
    flicker: number;
  }

  const embers: Ember[] = [];
  const EMBER_COUNT = 25;

  for (let i = 0; i < EMBER_COUNT; i++) {
    embers.push({
      x: Math.random() * canvas.width,
      y: canvas.height + Math.random() * 200,
      size: Math.random() * 2.5 + 0.5,
      speed: Math.random() * 0.6 + 0.2,
      opacity: Math.random() * 0.4 + 0.1,
      drift: (Math.random() - 0.5) * 0.3,
      flicker: Math.random() * Math.PI * 2,
    });
  }

  const colours = ["#fb923c", "#f97316", "#ea580c", "#fdba74", "#c2410c"];

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const ember of embers) {
      ember.y -= ember.speed;
      ember.x += Math.sin(ember.flicker) * ember.drift;
      ember.flicker += 0.02;

      const flickerOpacity =
        ember.opacity * (0.6 + 0.4 * Math.sin(ember.flicker * 3));

      ctx.beginPath();
      ctx.arc(ember.x, ember.y, ember.size, 0, Math.PI * 2);
      ctx.fillStyle =
        colours[Math.floor(Math.random() * colours.length)] +
        Math.round(flickerOpacity * 255)
          .toString(16)
          .padStart(2, "0");
      ctx.fill();

      // Reset when off screen
      if (ember.y < -10) {
        ember.y = canvas.height + 10;
        ember.x = Math.random() * canvas.width;
      }
    }

    requestAnimationFrame(draw);
  }

  draw();
</script>
