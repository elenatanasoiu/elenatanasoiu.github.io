---
import { socialLinks } from "../data/social";
---

<div class="flex items-center gap-4 pt-2">
  {
    socialLinks.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={link.name}
        class="text-text-muted hover:text-flame-400 transition-colors"
