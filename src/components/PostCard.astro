---
interface Props {
  title: string;
  date: string;
  description: string;
  slug: string;
  basePath: string;
}

const { title, date, description, slug, basePath } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<a
  href={`${basePath}/${slug}`}
  class="group block bg-surface-800 border border-surface-600 rounded-xl p-6 hover:border-flame-500/50 transition-all"
>
  <div class="space-y-3">
    <p class="text-text-muted text-sm font-mono">{formattedDate}</p>
    <h3
      class="text-text-primary font-semibold text-lg group-hover:text-flame-400 transition-colors"
    >
      {title}
    </h3>
    <p class="text-text-secondary text-sm line-clamp-2">{description}</p>
    <span
      class="inline-block text-flame-400 text-sm font-medium group-hover:translate-x-1 transition-transform"
    >
      Read more →
    </span>
  </div>
</a>
