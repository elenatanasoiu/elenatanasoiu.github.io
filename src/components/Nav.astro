---
const navItems = [
  { label: "About", href: "/#about" },
  { label: "Speaking", href: "/#speaking" },
  { label: "Blog", href: "/blog" },
  { label: "Writing", href: "/writing" },
  { label: "Games", href: "/games" },
  { label: "Flamegraph Viewer", href: "/flamegraph-viewer" },
];
---

<nav
  class="fixed top-0 w-full z-50 bg-surface-900/80 backdrop-blur-md border-b border-surface-700/50"
>
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="text-text-primary font-semibold text-lg hover:text-flame-400 transition-colors"
    >
      ET
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-text-secondary hover:text-flame-400 transition-colors text-sm font-medium"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-secondary hover:text-flame-400 transition-colors"
      aria-label="Toggle menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-menu"
    class="hidden md:hidden px-6 pb-4 border-b border-surface-700/50"
  >
    <ul class="flex flex-col gap-4">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-text-secondary hover:text-flame-400 transition-colors text-sm font-medium block py-1"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => menu?.classList.add("hidden"));
  });
</script>
