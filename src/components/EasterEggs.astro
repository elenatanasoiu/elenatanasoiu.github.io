<!-- Easter eggs collection -->

<!-- Cheatsheet modal (press ".") -->
<div
  id="egg-modal"
  class="fixed inset-0 z-[200] bg-surface-900/90 flex items-center justify-center hidden"
>
  <div class="bg-surface-800 border border-surface-600 rounded-xl p-8 max-w-md mx-4 space-y-4">
    <h2 class="text-flame-400 font-mono text-lg">🥚 Easter Eggs Cheatsheet</h2>
    <ul class="space-y-3 text-sm">
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">↑↑↓↓←→←→BA</span>
        <span class="text-text-secondary">Konami code → secret Mona photo</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">3× click name</span>
        <span class="text-text-secondary">Triple-click "Tănăsoiu" → fire cascade</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">hover photo 3s</span>
        <span class="text-text-secondary">Hold hover on photo → Mona swap</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">rage click</span>
        <span class="text-text-secondary">Click rapidly → CPU warning</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">click top bar</span>
        <span class="text-text-secondary">Click the flame gradient → rainbow + chime</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">/pickles</span>
        <span class="text-text-secondary">Secret pickle ranking page</span>
      </li>
      <li class="flex gap-3">
        <span class="text-flame-400 font-mono shrink-0">footer joke btn</span>
        <span class="text-text-secondary">Dad joke generator</span>
      </li>
    </ul>
    <p class="text-text-muted text-xs font-mono pt-2">press "." or click anywhere to close</p>
  </div>
</div>

<script>
  const eggModal = document.getElementById("egg-modal");

  document.addEventListener("keydown", (e) => {
    if (e.key === "." && !e.metaKey && !e.ctrlKey) {
      // Don't trigger if typing in an input
      if ((e.target as HTMLElement).tagName === "INPUT" || (e.target as HTMLElement).tagName === "TEXTAREA") return;
      eggModal?.classList.toggle("hidden");
    }
  });

  eggModal?.addEventListener("click", () => eggModal.classList.add("hidden"));
</script>

<!-- 1. Click flame bar → rainbow burst -->
<!-- 2. Triple-click name → fire cascade -->
<!-- 3. Hover photo 3s → Mona swap -->
<!-- 4. Rage click → CPU warning -->
<!-- 5. Click moon → snowflakes -->

<script>
  // === Rainbow flame bar on click ===
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target === document.body || target.closest("body")?.querySelector("body::after")) return;
  });

  // Top bar rainbow: click the very top 4px of the page
  document.addEventListener("click", (e) => {
    if (e.clientY <= 6) {
      const style = document.createElement("style");
      style.textContent = `
        body::after {
          background: linear-gradient(90deg, #ff0000, #ff8800, #ffff00, #00ff00, #0088ff, #8800ff, #ff0088, #ff0000) !important;
          background-size: 200% 100% !important;
          height: 4px !important;
          opacity: 1 !important;
        }
      `;
      document.head.appendChild(style);
      // Play a subtle "ding" via Web Audio
      try {
        const ctx = new AudioContext();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = 988; // B5
        gain.gain.value = 0.08;
        osc.start();
        osc.frequency.exponentialRampToValueAtTime(1319, ctx.currentTime + 0.1); // E6
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
        osc.stop(ctx.currentTime + 0.4);
      } catch {}
      setTimeout(() => style.remove(), 3000);
    }
  });

  // === Triple-click name → fire cascade ===
  let nameClicks = 0;
  let nameClickTimer: ReturnType<typeof setTimeout>;

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const h1 = target.closest("h1");
    if (!h1 || !h1.textContent?.includes("Tănăsoiu")) return;

    nameClicks++;
    clearTimeout(nameClickTimer);
    nameClickTimer = setTimeout(() => (nameClicks = 0), 500);

    if (nameClicks >= 3) {
      nameClicks = 0;
      const rect = h1.getBoundingClientRect();
      for (let i = 0; i < 30; i++) {
        const ember = document.createElement("div");
        ember.textContent = "🔥";
        ember.style.cssText = `
          position: fixed;
          left: ${rect.left + Math.random() * rect.width}px;
          top: ${rect.top}px;
          font-size: ${12 + Math.random() * 20}px;
          pointer-events: none;
          z-index: 9999;
          animation: ember-burst ${1 + Math.random() * 2}s ease-out forwards;
        `;
        document.body.appendChild(ember);
        setTimeout(() => ember.remove(), 3000);
      }
    }
  });

  // Add the burst animation
  const burstStyle = document.createElement("style");
  burstStyle.textContent = `
    @keyframes ember-burst {
      0% { opacity: 1; transform: translate(0, 0) rotate(0deg); }
      100% { opacity: 0; transform: translate(${() => "var(--dx)"}px, -200px) rotate(360deg); }
    }
  `;

  // Better: use individual animations per ember
  const burstCSS = document.createElement("style");
  burstCSS.textContent = `
    @keyframes ember-burst {
      0% { opacity: 1; transform: translateY(0) scale(1); }
      50% { opacity: 0.8; }
      100% { opacity: 0; transform: translateY(-300px) scale(0.3); }
    }
  `;
  document.head.appendChild(burstCSS);

  // === Hover photo 3s → Mona swap ===
  let hoverTimer: ReturnType<typeof setTimeout>;
  const profileImg = document.querySelector('img[alt="Elena Tănăsoiu"]') as HTMLImageElement;
  const originalSrc = profileImg?.src;

  profileImg?.addEventListener("mouseenter", () => {
    hoverTimer = setTimeout(() => {
      if (profileImg) {
        profileImg.style.transition = "opacity 0.3s ease";
        profileImg.style.opacity = "0";
        setTimeout(() => {
          profileImg.src = "/images/mona.png";
          profileImg.style.opacity = "1";
        }, 300);
      }
    }, 3000);
  });

  profileImg?.addEventListener("mouseleave", () => {
    clearTimeout(hoverTimer);
    if (profileImg && originalSrc && profileImg.src.includes("mona")) {
      profileImg.style.opacity = "0";
      setTimeout(() => {
        profileImg.src = originalSrc;
        profileImg.style.opacity = "1";
      }, 300);
    }
  });

  // === Rage click → CPU warning (disabled on game pages) ===
  const isGamePage = window.location.pathname.startsWith("/games/") && window.location.pathname !== "/games/";
  let clickTimes: number[] = [];

  document.addEventListener("click", () => {
    if (isGamePage) return;
    const now = Date.now();
    clickTimes.push(now);
    clickTimes = clickTimes.filter((t) => now - t < 1500);

    if (clickTimes.length >= 6) {
      clickTimes = [];
      const warning = document.createElement("div");
      warning.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #12121a;
        border: 1px solid #fb923c;
        border-radius: 12px;
        padding: 24px 32px;
        z-index: 9999;
        text-align: center;
        font-family: 'JetBrains Mono', monospace;
        box-shadow: 0 0 30px #fb923c40;
      `;
      warning.innerHTML = `
        <p style="font-size: 2rem; margin-bottom: 8px;">🔥</p>
        <p style="color: #fb923c; font-size: 0.875rem;">Easy there, you'll increase the CPU usage</p>
        <p style="color: #6b6b7b; font-size: 0.75rem; margin-top: 8px;">— your friendly performance engineer</p>
      `;
      document.body.appendChild(warning);
      setTimeout(() => {
        warning.style.transition = "opacity 0.5s ease";
        warning.style.opacity = "0";
        setTimeout(() => warning.remove(), 500);
      }, 2500);
    }
  });
</script>
