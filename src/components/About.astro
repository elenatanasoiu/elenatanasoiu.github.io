        </h3>
        <ul class="grid grid-cols-2 gap-2 text-sm text-text-secondary">
          {
            [
              "Ruby / Rails",
              "Go",
              "Flamegraphs",
              "Caching at Scale",
              "Observability",
              "Performance",
              "MySQL",
