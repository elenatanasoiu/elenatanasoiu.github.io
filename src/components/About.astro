<section id="about" class="py-24 reveal">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-2xl font-bold mb-2">
      <span class="text-flame-400 font-mono text-sm block mb-1">01.</span>
      About
    </h2>

    <div
      class="h-px bg-gradient-to-r from-flame-500/50 to-transparent mb-8 max-w-xs"
    >
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      <div class="md:col-span-2 space-y-4 text-text-secondary">
        <p>
          I'm a Staff Engineer on GitHub's <strong class="text-text-primary"
            >Performance Engineering</strong
